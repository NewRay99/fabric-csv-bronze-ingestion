			    VAR UnderOfferReferralIDs =
			        CALCULATETABLE(
			            VALUES(dim_referral[referral_id]),
			            dim_referral[referral_status] = "UNDER_OFFER"
			        )
			
			    VAR OfferIDs =
			        CALCULATETABLE(
			            VALUES(fact_referral_offer[offer_id]),
			            TREATAS(UnderOfferReferralIDs, fact_referral_offer[referral_id])
			        )
			
			    RETURN
			    CALCULATE(
			        DISTINCTCOUNT(fact_offer[offer_id]),
			        fact_offer[Is_Latest_Record] = 1,
			        dim_offer_status[offer_status_label] = "Pending",
			        TREATAS(OfferIDs, fact_offer[offer_id])
			    ),
			    0
			)
		formatString: 0
		displayFolder: Provider Activity KPIs
		lineageTag: 182eb22f-a4c1-4db5-900e-a4cf02238260


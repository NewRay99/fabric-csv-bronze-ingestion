	measure 'Draft Offer Count (Under Offer Referrals)' =
			
			VAR UnderOfferReferralIDs =
			    CALCULATETABLE(
			        VALUES(dim_referral[referral_id]),
			        dim_referral[referral_status] = "UNDER_OFFER"
			    )
			
			VAR DraftOfferIDs =
			    CALCULATETABLE(
			        VALUES(fact_referral_offer[offer_id]),
			        TREATAS(UnderOfferReferralIDs, fact_referral_offer[referral_id])
			    )
			
			RETURN
			COALESCE(
			    CALCULATE(
			        DISTINCTCOUNT(fact_offer[offer_id]),
			        fact_offer[Is_Latest_Record] = 1,
			        dim_offer_status[offer_status_label] = "Draft",
			        TREATAS(DraftOfferIDs, fact_offer[offer_id])
			    ),
			    0
			)
		formatString: 0
		displayFolder: Draft/Pending Offers
		lineageTag: 8562c005-0e24-4fd9-a7a5-e169eaaec9db

	measure 'Draft With No Activity Since Creation (%)' = ```
			

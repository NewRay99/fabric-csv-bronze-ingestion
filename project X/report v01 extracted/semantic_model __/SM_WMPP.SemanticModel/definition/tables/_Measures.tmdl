	measure 'Active Referrals With Provider Engagement' =
			
			VAR ActiveReferralIDs =
			    CALCULATETABLE(
			        VALUES(dim_referral[referral_id]),
			        REMOVEFILTERS(dim_date),
			        dim_referral[referral_status] IN {"OPEN", "UNDER_OFFER"}
			    )
			
			VAR EngagedReferralIDs =
			    CALCULATETABLE(
			        VALUES(fact_referral_offer[referral_id]),
			        REMOVEFILTERS(dim_date),
			        fact_referral_offer[is_cancelled] = FALSE(),
			        fact_referral_offer[is_closed] = FALSE(),
			        fact_referral_offer[is_excluded] = FALSE()
			    )
			
			VAR IntersectionIDs =
			    INTERSECT(
			        ActiveReferralIDs,
			        EngagedReferralIDs
			    )
			
			RETURN
			CALCULATE(
			    DISTINCTCOUNT(dim_referral[referral_id]),
			    REMOVEFILTERS(dim_date),
			    TREATAS(
			        IntersectionIDs,
			        dim_referral[referral_id]
			    )
			)
		formatString: 0
		displayFolder: Provider Activity KPIs
		lineageTag: 23283daf-e03b-4c88-8fbe-5c9d54c93057

	measure 'Active Referral Engagement Rate' = ```
			

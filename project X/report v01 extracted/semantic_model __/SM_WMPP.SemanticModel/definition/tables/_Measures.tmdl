			    )
			RETURN
			COALESCE(
			    CALCULATE(
			        DISTINCTCOUNT(dim_referral_gender[referral_id]),
			        TREATAS(FilteredReferrals, dim_referral_gender[referral_id])
			    ),
			    0
			)
		formatString: 0
		displayFolder: Referral Volume KPIs
		lineageTag: 79529786-b09c-4496-bc69-ff0f5bf8ed5d


table _Measures
	lineageTag: 712bae27-868f-4173-abe7-64ce2ab38422

	measure 'Total Referrals' = ```
			
			CALCULATE(
			    DISTINCTCOUNT(dim_referral[referral_id]),
			    USERELATIONSHIP(dim_date[Date], dim_referral[referral_date_only])
			)
			
			
			```
		formatString: 0
		displayFolder: Referral Volume KPIs
		lineageTag: 6323e309-be45-4771-93c9-b5940e7b3c14

	measure 'Referrals With Offers' = ```
			
			CALCULATE(
			    DISTINCTCOUNT(dim_referral[referral_id]),
			    USERELATIONSHIP(dim_date[Date], dim_referral[referral_date_only]),
			    dim_referral[referral_id] IN
			        CALCULATETABLE(
			            VALUES(fact_referral_offer[referral_id]),
			            fact_referral_offer[has_offer] = TRUE()
			        )
			)
			
			
			```
		formatString: 0
		displayFolder: Referral Volume KPIs
		lineageTag: 7f0f7b0e-df90-400b-a2a9-a4955a71daa7

	measure 'Referrals Awaiting Offer' = ```
			
			CALCULATE(
			    DISTINCTCOUNT(dim_referral[referral_id]),
			    USERELATIONSHIP(dim_date[Date], dim_referral[referral_date_only]),
			    NOT dim_referral[referral_id] IN
			        CALCULATETABLE(
			            VALUES(fact_referral_offer[referral_id]),
			            fact_referral_offer[has_offer] = TRUE()
			        )
			)
			
			```
		formatString: 0
		displayFolder: Referral Volume KPIs
		lineageTag: 76689445-0377-4e72-9b3b-7b5fa4d9b1a7

	measure 'No. Providers Who Made Offers' = ```
			
			VAR UnderOfferReferralIDs =
			    CALCULATETABLE(
			        VALUES(dim_referral[referral_id]),
			        dim_referral[referral_status] = "UNDER_OFFER"
			    )
			
			VAR ValidOfferIDs =
			    CALCULATETABLE(
			        VALUES(fact_offer[offer_id]),
			        fact_offer[Is_Latest_Record] = 1,
			        dim_offer_status[offer_status_label] <> "Draft"
			    )
			
			RETURN
			CALCULATE(
			    DISTINCTCOUNT(fact_referral_offer[provider_id]),
			    TREATAS(UnderOfferReferralIDs, fact_referral_offer[referral_id]),
			    TREATAS(ValidOfferIDs, fact_referral_offer[offer_id]),
			    NOT ISBLANK(fact_referral_offer[provider_id])
			)
			
			```
		formatString: 0
		displayFolder: Provider Activity KPIs
		lineageTag: fa759a7d-4361-48b4-95f4-9f9397ce05ee

	measure 'Total Offers Made Historically' = ```
			
			CALCULATE(
			    DISTINCTCOUNT(fact_offer[offer_id]),
			    fact_offer[Is_Latest_Record] = 1,
			    KEEPFILTERS(dim_offer_status[offer_status_label] <> "Draft")
			)
			
			```
		formatString: 0
		displayFolder: Provider Activity KPIs
		lineageTag: a60e7175-e2be-4aff-b11e-252839c54ae0

	measure 'Avg Offers per Referral Under Offer' = ```
			
			DIVIDE(
			    [Total Offers Made (Active Referrals Under Offer)],
			    [Active Referrals Under Offer],
			    0
			)
			
			```
		displayFolder: Provider Activity KPIs
		lineageTag: bfe9a2e9-a57e-4984-b3ec-58bf784bf06f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Avg Offers per Provider (Under Offer)' =
			
			DIVIDE(
			    [Total Offers Made (Active Referrals Under Offer)],
			    [No. Providers Who Made Offers],
			    0
			)
		displayFolder: Provider Activity KPIs
		lineageTag: 486d4d4c-7e13-4746-ba81-0bef2c94f802

		annotation PBI_FormatHint = {"isGeneralNumber":true}


	measure 'Latest Offer Status Count' =
			
			VAR LatestOffers =
			    ADDCOLUMNS(
			        SUMMARIZE(
			            fact_offer,
			            fact_offer[offer_id]
			        ),
			        "LatestDate",
			            CALCULATE(MAX(fact_offer[export_date]))
			    )
			
			RETURN
			CALCULATE(
			    DISTINCTCOUNT(fact_offer[offer_id]),
			    TREATAS(
			        LatestOffers,
			        fact_offer[offer_id],
			        fact_offer[export_date]
			    )
			)
		formatString: 0
		displayFolder: Miscellaneous Queries
		lineageTag: 19ad85dd-1b85-4f1f-a782-96b859621732

	measure 'Total Gendered Referrals' =
			

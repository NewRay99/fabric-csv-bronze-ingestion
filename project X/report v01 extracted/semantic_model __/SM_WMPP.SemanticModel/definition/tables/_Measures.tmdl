	measure 'Referrals Currently Active' =
			
			VAR LatestExportDate =
			    MAXX(
			        ALL(dim_referral),
			        dim_referral[Export Date Clean]
			    )
			
			VAR LiveProviderReferralIDs =
			    CALCULATETABLE(
			        VALUES(fact_referral_offer[referral_id]),
			        REMOVEFILTERS(fact_referral_offer),
			        REMOVEFILTERS(dim_date),
			        fact_referral_offer[is_cancelled] = FALSE(),
			        fact_referral_offer[is_closed] = FALSE(),
			        fact_referral_offer[is_excluded] = FALSE()
			    )
			
			VAR OpenWithinResponseWindowIDs =
			    CALCULATETABLE(
			        VALUES(dim_referral[referral_id]),
			        REMOVEFILTERS(dim_date),
			        dim_referral[referral_status] = "OPEN",
			        dim_referral[Response Required Date Clean] >= LatestExportDate
			    )
			
			VAR ActiveOpenReferralIDs =
			    DISTINCT(
			        UNION(
			            LiveProviderReferralIDs,
			            OpenWithinResponseWindowIDs
			        )
			    )
			
			VAR UnderOfferReferralIDs =
			    CALCULATETABLE(
			        VALUES(dim_referral[referral_id]),
			        REMOVEFILTERS(dim_date),
			        dim_referral[referral_status] = "UNDER_OFFER"
			    )
			
			VAR CombinedActiveReferralIDs =
			    DISTINCT(
			        UNION(
			            ActiveOpenReferralIDs,
			            UnderOfferReferralIDs
			        )
			    )
			
			RETURN
			CALCULATE(
			    DISTINCTCOUNT(dim_referral[referral_id]),
			    REMOVEFILTERS(dim_date),
			    dim_referral[referral_status] IN { "OPEN", "UNDER_OFFER" },
			    TREATAS(
			        CombinedActiveReferralIDs,
			        dim_referral[referral_id]
			    )
			)
		formatString: 0
		displayFolder: Referral Offers
		lineageTag: c38981f9-2b39-4084-ac10-c1e7f88f3f07

	measure 'Active Referrals Under Offer' = ```
			
			VAR AcceptedOffers =
			    CALCULATETABLE(
			        VALUES(fact_offer[offer_id]),
			        fact_offer[Is_Latest_Record] = 1,
			        fact_offer[offer_status] = "OFFER_SUCCESSFUL"
			    )
			
			VAR ReferralIDs =
			    CALCULATETABLE(
			        VALUES(fact_referral_offer[referral_id]),
			        TREATAS(AcceptedOffers, fact_referral_offer[offer_id])
			    )
			
			RETURN
			COUNTROWS(
			    DISTINCT(ReferralIDs)
			)
			
			```
		formatString: 0
		displayFolder: Referral Offers
		lineageTag: 238dd258-9c43-4841-8f2d-1e446ce2e72a

	measure 'Referrals Cancelled/Closed' = ```
			
			CALCULATE(
			    DISTINCTCOUNT(dim_referral[referral_id]),
			    USERELATIONSHIP(dim_date[Date], dim_referral[referral_date_only]),
			    dim_referral[referral_status] IN { "CANCELLED", "CLOSED" }

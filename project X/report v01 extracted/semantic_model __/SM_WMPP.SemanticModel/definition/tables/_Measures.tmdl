	measure 'Is IPA Pending' =
			
			VAR CurrentOffer =
			    SELECTEDVALUE(fact_ipa[offer_id])
			
			RETURN
			IF(
			    CALCULATE(
			        COUNTROWS(fact_ipa),
			        FILTER(
			            fact_ipa,
			            fact_ipa[offer_id] = CurrentOffer &&
			            NOT (
			                COALESCE(fact_ipa[signed_by_provider], FALSE()) = TRUE() &&
			                COALESCE(fact_ipa[signed_by_local_authority], FALSE()) = TRUE()
			            )
			        )
			    ) > 0,
			    1,
			    0
			)
		formatString: 0
		displayFolder: IPA Measures
		lineageTag: c6dc9179-c710-49fd-8909-8cc69d8ceb38

	measure 'Is Awaiting IPA Creation' =
			
			VAR CurrentOffer =
			    SELECTEDVALUE(fact_offer[offer_id])
			
			VAR BaseOffers =
			    CALCULATETABLE(
			        VALUES(fact_offer[offer_id]),
			        fact_offer[Is_Latest_Record] = 1,
			        fact_offer[offer_status] = "OFFER_SUCCESSFUL"
			    )
			
			VAR IPAOffers =
			    CALCULATETABLE(
			        VALUES(fact_ipa[offer_id]),
			        TREATAS(BaseOffers, fact_ipa[offer_id])
			    )
			
			RETURN
			IF(
			    CurrentOffer IN EXCEPT(BaseOffers, IPAOffers),
			    1,
			    0
			)
		formatString: 0
		displayFolder: IPA Measures
		lineageTag: 058b9fac-f4cd-492f-ac2d-39d20c70b376

	measure 'Is IPA Completed' =
			
			VAR CurrentOffer =
			    SELECTEDVALUE(fact_offer[offer_id])
			
			RETURN
			IF(
			    CALCULATE(
			        COUNTROWS(fact_ipa),
			        FILTER(
			            fact_ipa,
			            fact_ipa[offer_id] = CurrentOffer &&
			            COALESCE(fact_ipa[signed_by_provider], FALSE()) = TRUE() &&
			            COALESCE(fact_ipa[signed_by_local_authority], FALSE()) = TRUE()
			        )
			    ) > 0,
			    1,
			    0
			)
		formatString: 0
		displayFolder: IPA Measures
		lineageTag: 5158372f-9e2a-4e4b-8dff-bb7776795aac

	measure 'Accepted Offer to IPA Conversion %' = ```
			
			DIVIDE(
			    [IPA Created],
			    CALCULATE(
			        DISTINCTCOUNT(fact_offer[offer_id]),
			        fact_offer[Is_Latest_Record] = 1,
			        fact_offer[offer_status] = "OFFER_SUCCESSFUL"
			    ),
			    0
			)
			
			```
		displayFolder: IPA Measures
		lineageTag: 6905e0dd-36c7-495e-9c4f-739bed3a64b6

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Offers Still to Progress to IPA' =
			
			DIVIDE(
			    [Offers Awaiting IPA Creation],
			    CALCULATE(
			        DISTINCTCOUNT(fact_offer[offer_id]),
			        fact_offer[Is_Latest_Record] = 1,
			        fact_offer[offer_status] = "OFFER_SUCCESSFUL"
			    ),
			    0
			)
		displayFolder: IPA Measures
		lineageTag: 202fc7f6-a1af-4a44-b046-a81f7dac2b9a

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'IPA Created to Completion %' = ```
			
			DIVIDE(
			    [IPA Completed],
			    [IPA Created],
			    0
			)
			
			```
		displayFolder: IPA Measures
		lineageTag: f5fda4ea-024a-4890-9c2c-48812dda6409

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Successful Offers to IPA Completed %' = ```
			
			DIVIDE(
			    [IPA Completed],
			    CALCULATE(
			        DISTINCTCOUNT(fact_offer[offer_id]),
			        fact_offer[Is_Latest_Record] = 1,
			        fact_offer[offer_status] = "OFFER_SUCCESSFUL"
			    ),
			    0
			)
			
			```
		displayFolder: IPA Measures
		lineageTag: 4d78fd96-29ad-45a3-ab50-e4dddad3b585

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Overlap Referrals' =
			
			[Active Referrals Awaiting Offers]
			+ [Active Referrals Under Offer]
			- [Referrals Currently Active]
		formatString: 0
		lineageTag: 54c2b74a-7a4a-4821-8086-5a7d8d0e618c

	measure 'Open Referral' =
			
			CALCULATE ( DISTINCTCOUNT(dim_referral[referral_id]), dim_referral[referral_status] IN {"OPEN", "UNDER_OFFER"})
		formatString: 0
		displayFolder: Referral Offers
		lineageTag: 34758a00-8077-40f6-87c6-5a6a839100ef

	measure 'Open Referral Previous Month' =
			
			CALCULATE ([Open Referral], DATEADD(dim_date[Date],-1,MONTH))
		formatString: 0
		displayFolder: Referral Offers
		lineageTag: f1ba9238-f3d5-456e-ab4f-72fe9ec46554

	measure 'Closed Referral Previous Month' =
			
			CALCULATE ([Closed Referrals (by Reason)], DATEADD(dim_date[Date],-1,MONTH))
		formatString: 0
		displayFolder: Referral Offers
		lineageTag: f8135835-6571-49ca-b162-131940337c2e

	measure 'Open Referrals MoM %' = DIVIDE ([Open Referral]-[Open Referral Previous Month],[Open Referral Previous Month])
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Referral Offers
		lineageTag: 34c46f6a-ca43-4836-bddc-f2c5040e9cef

	measure 'Closed Referrals MoM %' = DIVIDE ([Closed Referrals (by Reason)]-[Closed Referral Previous Month],[Closed Referral Previous Month])
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Referral Offers
		lineageTag: 28109811-acd8-400c-a70a-7a0a515a3788

	partition _Measures = m
		mode: import
		source =
				let
				    Source = Table.FromRows(Json.Document(Binary.Decompress(Binary.FromText("i44FAA==", BinaryEncoding.Base64), Compression.Deflate)), let _t = ((type nullable text) meta [Serialized.Text = true]) in type table [Column1 = _t]),
				    #"Changed Type" = Table.TransformColumnTypes(Source,{{"Column1", type text}}),
				    #"Removed Columns" = Table.RemoveColumns(#"Changed Type",{"Column1"})
				in
				    #"Removed Columns"

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table


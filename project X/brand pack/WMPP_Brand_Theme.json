{
  "name": "WMPP — Birmingham Children's Trust",
  "dataColors": [
    "#FCBF00",
    "#F59E00",
    "#EF7911",
    "#FFE672",
    "#575756",
    "#1D1D1B",
    "#3A8B6F",
    "#C0392B"
  ],
  "background": "#EDEDED",
  "foreground": "#1D1D1B",
  "tableAccent": "#FCBF00",
  "good": "#3A8B6F",
  "neutral": "#F59E00",
  "bad": "#C0392B",
  "maximum": "#EF7911",
  "center": "#FCBF00",
  "minimum": "#FFE672",
  "null": "#B9B9B7",
  "hyperlink": "#575756",
  "visitedHyperlink": "#575756",
  "backgroundLight": "#FFFFFF",
  "backgroundNeutral": "#EDEDED",
  "foregroundNeutralSecondary": "#575756",
  "foregroundNeutralTertiary": "#777775",
  "textClasses": {
    "callout": {
      "fontSize": 30,
      "fontFace": "Lato",
      "color": "#1D1D1B"
    },
    "title": {
      "fontSize": 13,
      "fontFace": "Lato",
      "color": "#1D1D1B"
    },
    "header": {
      "fontSize": 12,
      "fontFace": "Lato",
      "color": "#1D1D1B"
    },
    "label": {
      "fontSize": 11,
      "fontFace": "Lato",
      "color": "#575756"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#D6D6D4"
              }
            },
            "radius": 4
          }
        ],
        "title": [
          {
            "show": true,
            "fontFace": "Lato",
            "fontSize": 13,
            "fontColor": {
              "solid": {
                "color": "#1D1D1B"
              }
            }
          }
        ],
        "categoryAxis": [
          {
            "showAxisTitle": true,
            "gridlineStyle": "dotted",
            "concatenateLabels": false
          }
        ],
        "valueAxis": [
          {
            "showAxisTitle": true,
            "gridlineStyle": "dotted"
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "fontFace": "Lato",
            "fontSize": 30,
            "color": {
              "solid": {
                "color": "#1D1D1B"
              }
            }
          }
        ],
        "categoryLabels": [
          {
            "show": true,
            "fontFace": "Lato",
            "fontSize": 11,
            "color": {
              "solid": {
                "color": "#575756"
              }
            }
          }
        ]
      }
    },
    "tableEx": {
      "*": {
        "columnHeaders": [
          {
            "fontFace": "Lato",
            "fontSize": 11,
            "fontColor": {
              "solid": {
                "color": "#1D1D1B"
              }
            },
            "backColor": {
              "solid": {
                "color": "#FCBF00"
              }
            }
          }
        ]
      }
    }
  }
}

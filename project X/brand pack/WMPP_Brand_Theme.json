{
  "name": "WMPP_Brand_Theme_BCT_v1",
  "dataColors": [
    "#FCBF00",
    "#F59E00",
    "#EF7911",
    "#FFE672",
    "#2E3E71",
    "#AFD9FF",
    "#C82B5E",
    "#3A8B6F",
    "#C0392B",
    "#1C1C1A",
    "#F9B234",
    "#F1F8FF"
  ],
  "background": "#FFFDF8",
  "foreground": "#1C1C1A",
  "tableAccent": "#F59E00",
  "good": "#3A8B6F",
  "neutral": "#FCBF00",
  "bad": "#C0392B",
  "maximum": "#F59E00",
  "center": "#FCBF00",
  "minimum": "#FFE672",
  "null": "#A7A4A0",
  "hyperlink": "#2E3E71",
  "visitedHyperlink": "#2E3E71",
  "backgroundLight": "#FFFFFF",
  "backgroundNeutral": "#E6E1D7",
  "foregroundNeutralSecondary": "#5C5A56",
  "foregroundNeutralTertiary": "#8A8780",
  "textClasses": {
    "callout": {
      "fontSize": 28,
      "fontFace": "Poppins",
      "color": "#1C1C1A"
    },
    "title": {
      "fontSize": 13,
      "fontFace": "Poppins",
      "color": "#1C1C1A"
    },
    "header": {
      "fontSize": 12,
      "fontFace": "Poppins Semibold",
      "color": "#1C1C1A"
    },
    "label": {
      "fontSize": 11,
      "fontFace": "Inter",
      "color": "#5C5A56"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "*": [
          {
            "wordWrap": true
          }
        ],
        "categoryAxis": [
          {
            "showAxisTitle": true,
            "gridlineStyle": "dotted",
            "concatenateLabels": false
          }
        ],
        "valueAxis": [
          {
            "showAxisTitle": true,
            "gridlineStyle": "dotted"
          }
        ],
        "line": [
          {
            "transparency": 0
          }
        ],
        "outline": [
          {
            "transparency": 0
          }
        ],
        "plotArea": [
          {
            "transparency": 0
          }
        ],
        "background": [
          {
            "show": true,
            "transparency": 0
          }
        ],
        "border": [
          {
            "width": 1
          }
        ],
        "outspacePane": [
          {
            "backgroundColor": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "transparency": 0,
            "border": true,
            "borderColor": {
              "solid": {
                "color": "#E0DDD5"
              }
            }
          }
        ],
        "filterCard": [
          {
            "$id": "Applied",
            "transparency": 0,
            "foregroundColor": {
              "solid": {
                "color": "#1C1C1A"
              }
            },
            "border": true
          },
          {
            "$id": "Available",
            "transparency": 0,
            "foregroundColor": {
              "solid": {
                "color": "#1C1C1A"
              }
            },
            "border": true
          }
        ]
      }
    },
    "cardVisual": {
      "*": {
        "layout": [
          {
            "maxTiles": 3
          },
          {
            "$id": "default",
            "cellPadding": 14,
            "paddingIndividual": false,
            "paddingUniform": 14,
            "backgroundShow": true
          }
        ],
        "image": [
          {
            "$id": "default",
            "position": "Left",
            "imageAreaSize": 20,
            "padding": 14,
            "rectangleRoundedCurve": 8,
            "fit": "Normal",
            "fixedSize": false
          }
        ],
        "referenceLabel": [
          {
            "$id": "default",
            "backgroundColor": {
              "solid": {
                "color": "backgroundLight"
              }
            },
            "paddingUniform": 14,
            "rectangleRoundedCurveCustomStyle": true,
            "rectangleRoundedCurveLeftBottom": 8,
            "rectangleRoundedCurveRightBottom": 8
          }
        ]
      }
    },
    "donutChart": {
      "*": {
        "legend": [
          {
            "show": true,
            "position": "RightCenter"
          }
        ],
        "labels": [
          {
            "labelStyle": "Data value, percent of total"
          }
        ]
      }
    },
    "pieChart": {
      "*": {
        "legend": [
          {
            "show": true,
            "position": "RightCenter"
          }
        ],
        "labels": [
          {
            "labelStyle": "Data value, percent of total"
          }
        ]
      }
    },
    "pivotTable": {
      "*": {
        "rowHeaders": [
          {
            "showExpandCollapseButtons": true,
            "legacyStyleDisabled": true
          }
        ]
      }
    },
    "multiRowCard": {
      "*": {
        "card": [
          {
            "outlineWeight": 2,
            "barShow": true,
            "barWeight": 2
          }
        ]
      }
    },
    "kpi": {
      "*": {
        "trendline": [
          {
            "transparency": 20
          }
        ]
      }
    }
  }
}
